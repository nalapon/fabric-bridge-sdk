{
  "name": "fabric-bridge-sdk",
  "version": "0.1.0",
  "description": "Bridge SDK combining fabric-gateway and fabric-network with peer targeting support",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "bun test test/integration/initLedger.test.ts",
    "test:integration": "bun test test/integration/",
    "example": "bun run examples/app.ts",
    "example:app": "bun run examples/app.ts"
  },
  "keywords": [
    "hyperledger",
    "fabric",
    "blockchain",
    "gateway",
    "network",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@hyperledger/fabric-gateway": "^1.10.1",
    "better-result": "^2.7.0",
    "fabric-network": "^2.2.20"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
